{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clippy",
  "version": "0.1.0",
  "identifier": "com.yidejia.clippy",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "clippy",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "height": 322,
        "x": 0
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
